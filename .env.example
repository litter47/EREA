# EVA-Agent Environment Configuration
# Copy this file to .env and modify as needed

# LLM Configuration (overrides config/llm.yaml)
# Uncomment and set values to enable LLM judge
# EVA_LLM_PROVIDER=openai
# EVA_LLM_BASE_URL=https://api.openai.com/v1
# EVA_LLM_API_KEY=sk-your-key-here
# EVA_LLM_MODEL=gpt-4.1
# EVA_LLM_ENABLED=false

# For local models (Ollama / vLLM / LM Studio):
# EVA_LLM_PROVIDER=ollama
# EVA_LLM_BASE_URL=http://host.docker.internal:11434/v1
# EVA_LLM_API_KEY=not-needed
# EVA_LLM_MODEL=qwen2.5
# EVA_LLM_ENABLED=true

# EVA-Agent Settings
# EVA_HOST=0.0.0.0
# EVA_PORT=8000
# EVA_TASK_TIMEOUT=300
